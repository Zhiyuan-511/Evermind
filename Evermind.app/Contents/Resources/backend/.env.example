# ═══════════════════════════════════════════
# Evermind Backend — Environment Variables
# ═══════════════════════════════════════════

# AI Model API Keys (add keys for models you want to use)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-key
DEEPSEEK_API_KEY=your-deepseek-key
KIMI_API_KEY=your-kimi-moonshot-key
QWEN_API_KEY=your-qwen-dashscope-key

# Server
HOST=0.0.0.0
PORT=8765
DEBUG=true

# Workspace
WORKSPACE=/Users/you/Desktop
OUTPUT_DIR=/tmp/evermind_output

# Security
MAX_FILE_SIZE_MB=10
ALLOWED_DIRS=/tmp,/Users/you/Desktop
SHELL_TIMEOUT=30

# Builder quality controls
# 0 = stable local mode (recommended), 1 = allow builder to use browser tool for quick style research
EVERMIND_BUILDER_ENABLE_BROWSER=0
# Maximum emoji glyphs allowed in generated HTML (0 = disallow emoji icons)
EVERMIND_MAX_EMOJI_GLYPHS=0
# Tester deterministic visual gate: 1 = run Playwright smoke check, 0 = structure-only validation
EVERMIND_TESTER_RUN_SMOKE=1
# Browser plugin mode: 0 = headless (silent), 1 = headful (visible window)
EVERMIND_BROWSER_HEADFUL=0
# Max per-subtask retry count (clamped to 1..8)
EVERMIND_MAX_RETRIES=3
