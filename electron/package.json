{
    "name": "evermind-desktop",
    "version": "3.0.0",
    "description": "Evermind — AI Workflow Orchestrator Desktop App",
    "main": "main.js",
    "author": "Evermind Team",
    "license": "MIT",
    "scripts": {
        "start": "electron .",
        "build:frontend": "cd ../frontend && npm run build",
        "prepare:frontend-bundle": "node scripts/prepare_frontend_bundle.js",
        "sign:app": "node scripts/ad_hoc_sign_app.js",
        "sync:local-app": "node scripts/sync_local_app_resources.js",
        "sync:desktop": "node scripts/sync_desktop_app.js",
        "doctor:runtime": "python3 ../backend/scripts/release_doctor.py",
        "doctor:runtime:json": "python3 ../backend/scripts/release_doctor.py --json",
        "doctor:report": "python3 ../backend/scripts/release_doctor.py --full-json --write-report",
        "hardening:test": "python3 -m pytest ../backend/tests/test_release_doctor.py ../backend/tests/test_packaged_backend_sync.py ../backend/tests/test_hot_reload.py ../backend/tests/test_task_classifier.py ../backend/tests/test_workflow_launch.py -q",
        "hardening:check": "npm run hardening:test && npm run pack && npm run sync:local-app && npm run sync:desktop && python3 ../backend/scripts/release_doctor.py --strict",
        "pack": "npm run build:frontend && npm run prepare:frontend-bundle && electron-builder --dir && npm run sign:app",
        "pack:desktop": "npm run pack && npm run sync:desktop",
        "dist": "npm run build:frontend && npm run prepare:frontend-bundle && electron-builder && npm run sign:app",
        "build": "npm run dist"
    },
    "dependencies": {
        "electron-is-dev": "^2.0.0",
        "tree-kill": "^1.2.2"
    },
    "devDependencies": {
        "electron": "^33.0.0",
        "electron-builder": "^25.0.0"
    },
    "build": {
        "appId": "com.evermind.desktop",
        "productName": "Evermind",
        "asar": true,
        "mac": {
            "category": "public.app-category.developer-tools",
            "icon": "icon.icns",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "arm64"
                    ]
                },
                {
                    "target": "dir",
                    "arch": [
                        "arm64"
                    ]
                }
            ],
            "darkModeSupport": true,
            "hardenedRuntime": true,
            "entitlements": "build/entitlements.mac.plist",
            "entitlementsInherit": "build/entitlements.mac.plist",
            "gatekeeperAssess": false,
            "identity": null,
            "extendInfo": {
                "NSDesktopFolderUsageDescription": "Evermind saves exported workflow outputs and previews to the Desktop.",
                "NSDocumentsFolderUsageDescription": "Evermind reads project assets referenced by your prompts and writes generated results to Documents.",
                "NSDownloadsFolderUsageDescription": "Evermind exports packaged builds to the Downloads folder.",
                "NSAppleEventsUsageDescription": "Evermind uses AppleScript to launch the browser preview after a run completes.",
                "NSNetworkVolumesUsageDescription": "Evermind reads and writes project workspaces on network volumes you select.",
                "NSRemovableVolumesUsageDescription": "Evermind reads and writes project workspaces on external drives you select.",
                "LSEnvironment": {
                    "EVERMIND_TCC_BUNDLE": "1"
                }
            }
        },
        "protocols": [
            {
                "name": "Evermind",
                "schemes": [
                    "evermind"
                ]
            }
        ],
        "files": [
            "main.js",
            "qa-session.js",
            "preload.js",
            "splash.html",
            "package.json",
            "node_modules/**/*"
        ],
        "extraResources": [
            {
                "from": "../backend",
                "to": "backend",
                "filter": [
                    "**/*.py",
                    "!bench/**",
                    "!tests/**",
                    "!scripts/desktop_run_goal_monitor.py",
                    "agent_skills/**",
                    "runtime_vendor/**",
                    "requirements.txt",
                    ".env.example",
                    "plugins/**",
                    "prompt_templates/**/*.yaml",
                    "prompt_templates/**/*.yml"
                ]
            },
            {
                "from": ".packaged/frontend-standalone",
                "to": "frontend-standalone"
            },
            {
                "from": "../evermind_godmode_final.html",
                "to": "evermind_godmode_final.html"
            }
        ],
        "dmg": {
            "title": "Evermind Installer",
            "backgroundColor": "#0f1117",
            "contents": [
                {
                    "x": 130,
                    "y": 220
                },
                {
                    "x": 410,
                    "y": 220,
                    "type": "link",
                    "path": "/Applications"
                }
            ]
        }
    }
}